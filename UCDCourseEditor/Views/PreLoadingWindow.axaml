<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="UCDCourseEditor.Views.PreLoadingWindow"
        Width="400" Height="230"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        Title="PreLoadingWindow">

    <Grid>
        <Image Source="avares://UCDCourseEditor/Assets/images.jpg" Stretch="UniformToFill"/>
        <Rectangle Fill="Black" Opacity="0.3" VerticalAlignment="Top" Height="{Binding $parent[Window].Height}"/>
        <TextBlock Text="Ładowanie...😊😊😊" 
                   VerticalAlignment="Bottom" HorizontalAlignment="Center" 
                   Margin="0,0,0,5" FontSize="18" FontWeight="Bold" Foreground="#949494"/>
    </Grid>

</Window>